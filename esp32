// =====================================================
void setup()
{
  Serial.begin(115200);
  Serial2.begin(9600, SERIAL_8N1, RXD2, TXD2);

  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
  }

  Serial.println("WiFi Connected!");
  Serial.println(WiFi.localIP());

  server.on("/", handleRoot);

  // ================= DDoS =================
  server.on("/ddos", []() {
    sendPacket(
      1,      // proto
      7,      // conn_state
      1000,   // src_port
      80,     // dst_port
      5,      // duration small
      500000, // src_bytes very high
      600000  // dst_bytes very high
    );
    handleRoot();
  });

  // ================= PORT SCAN =================
  server.on("/portscan", []() {
    sendPacket(
      1,
      3,
      3,
      21,
      10,
      50,
      80
    );
    handleRoot();
  });

  // ================= BRUTE FORCE =================
  server.on("/bruteforce", []() {
    sendPacket(
      1,
      5,
      2,
      21,
      30,
      40,
      60
    );
    handleRoot();
  });

  // ================= NORMAL =================
  server.on("/normal", []() {
    sendPacket(
      3,
      0,
      40000,
      40000,
      500,
      100000,
      100000
    );
    handleRoot();
  });

  server.begin();
}

// =====================================================
void loop()
{
  server.handleClient();
}
