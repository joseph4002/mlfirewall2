#include <WiFi.h>
#include <WebServer.h>

// ================= UART CONFIG =================
#define RXD2 16
#define TXD2 17

// ================= WIFI ========================
const char* ssid     = "iQOO Z9 5G";
const char* password = "jes12345";

// ================= SERVER ======================
WebServer server(80);
String resultText = "Waiting...";

// =====================================================
// Send 16-Byte Packet (Matches firewall_top exactly)
// =====================================================
void sendPacket(uint8_t proto,
                uint8_t conn_state,
                uint16_t src_port,
                uint16_t dst_port,
                uint16_t duration,
                uint32_t src_bytes,
                uint32_t dst_bytes)
{
  while (Serial2.available()) Serial2.read();

  Serial2.write(proto);
  Serial2.write(conn_state);

  Serial2.write(lowByte(src_port));
  Serial2.write(highByte(src_port));

  Serial2.write(lowByte(dst_port));
  Serial2.write(highByte(dst_port));

  Serial2.write(lowByte(duration));
  Serial2.write(highByte(duration));

  Serial2.write((uint8_t)(src_bytes));
  Serial2.write((uint8_t)(src_bytes >> 8));
  Serial2.write((uint8_t)(src_bytes >> 16));
  Serial2.write((uint8_t)(src_bytes >> 24));

  Serial2.write((uint8_t)(dst_bytes));
  Serial2.write((uint8_t)(dst_bytes >> 8));
  Serial2.write((uint8_t)(dst_bytes >> 16));
  Serial2.write((uint8_t)(dst_bytes >> 24));

  unsigned long startTime = millis();

  while (millis() - startTime < 500) {
    if (Serial2.available()) {
      char response = Serial2.read();

      if (response == 'A')
        resultText = "ATTACK DETECTED 🔴";
      else if (response == 'N')
        resultText = "NORMAL TRAFFIC 🟢";
      else
        resultText = "UNKNOWN RESPONSE";

      return;
    }
  }

  resultText = "NO RESPONSE FROM FPGA";
}

// =====================================================
// Web Page
// =====================================================
